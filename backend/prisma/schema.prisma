generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampanhaStatus {
  ativa
  encerrada
}

enum ParcelaStatus {
  pendente
  paga
}

enum CarneStatus {
  ativo
  cancelado
}

enum MetodoPagamento {
  dinheiro
  pix
}

enum UsuarioRole {
  admin
  tesoureiro
}

model Usuario {
  id        String      @id @default(uuid())
  nome      String
  email     String      @unique
  senhaHash String      @map("senha_hash")
  role      UsuarioRole @default(tesoureiro)
  criadoEm DateTime    @default(now()) @map("criado_em")

  pagamentos Pagamento[]

  @@map("usuario")
}

model Campanha {
  id          String         @id @default(uuid())
  nome        String
  premio      String
  dataSorteio DateTime       @map("data_sorteio") @db.Date
  valorCarne  Decimal        @map("valor_carne") @db.Decimal(10, 2)
  numParcelas Int            @map("num_parcelas")
  maxCarnes   Int            @map("max_carnes")
  status      CampanhaStatus @default(ativa)
  criadoEm   DateTime       @default(now()) @map("criado_em")

  carnes Carne[]

  @@map("campanha")
}

model Participante {
  id        String   @id @default(uuid())
  nome      String
  cpf       String?  @unique
  telefone  String?
  endereco  String?
  criadoEm DateTime @default(now()) @map("criado_em")

  carnes Carne[]

  @@map("participante")
}

model Carne {
  id             String      @id @default(uuid())
  campanhaId     String      @map("campanha_id")
  participanteId String      @map("participante_id")
  numeroSorte    Int         @map("numero_sorte")
  status         CarneStatus @default(ativo)
  criadoEm      DateTime    @default(now()) @map("criado_em")

  campanha     Campanha     @relation(fields: [campanhaId], references: [id])
  participante Participante @relation(fields: [participanteId], references: [id])
  parcelas     Parcela[]

  @@unique([campanhaId, numeroSorte])
  @@map("carne")
}

model Parcela {
  id      String        @id @default(uuid())
  carneId String        @map("carne_id")
  numero  Int
  status  ParcelaStatus @default(pendente)

  carne      Carne       @relation(fields: [carneId], references: [id])
  pagamentos Pagamento[]

  @@unique([carneId, numero])
  @@map("parcela")
}

model Pagamento {
  id            String          @id @default(uuid())
  parcelaId     String          @map("parcela_id")
  usuarioId     String          @map("usuario_id")
  valorPago     Decimal         @map("valor_pago") @db.Decimal(10, 2)
  dataPagamento DateTime        @map("data_pagamento") @db.Date
  criadoEm     DateTime        @default(now()) @map("criado_em")
  metodo        MetodoPagamento
  referencia    String?

  parcela Parcela @relation(fields: [parcelaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("pagamento")
}
